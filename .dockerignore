# ============================================================
#  .dockerignore — Create Delight Remake
#  排除不需要打包进镜像的文件，减小构建上下文体积
# ============================================================

# Windows 启动脚本（容器内不需要）
start.bat
variables.txt

# PCL 启动器配置（客户端专用）
PCL/

# 热爱相关（客户端专用）
hotai/

# 迷你菜单（客户端专用）
minemenu/

# 图标（已由 Dockerfile 单独 COPY）
# icon.png  ← 保留 server-icon.png，排除 icon.png
icon.png

# 服务器运行时生成的文件（会落入 /data 卷）
world/
world_nether/
world_the_end/
logs/
crash-reports/
*.log
eula.txt
server.properties
user_jvm_args.txt
ops.json
whitelist.json
banned-ips.json
banned-players.json
usercache.json

# Forge 安装后生成的文件（由 forge-installer 阶段处理）
run.sh
run.bat
libraries/
unix_args.txt
win_args.txt

# 开发 / 文档
.git/
.gitignore
.github/
README*
readme*
CHANGELOG*
*.md
docs/

# macOS / Windows 系统文件
.DS_Store
Thumbs.db
desktop.ini

# IDE / 编辑器
.idea/
.vscode/
*.iml
